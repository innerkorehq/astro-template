---
import { getPageByPath, getPageTree, getSeoMeta } from "@/db/index";
import { resolveBlocks } from "@/lib/blocks/resolver";
import type { Block } from "@/lib/blocks/types";
import Layout from "@/layouts/Layout.astro";
import BlockRenderer from "@/components/BlockRenderer.astro";

export async function getStaticPaths() {
  const pages = await getPageTree();
  return pages
    .filter((p) => p.status === "published" && p.deleted_at === null && p.path !== "/")
    .map((p) => ({ params: { slug: p.path.replace(/^\//, "") } }));
}

const { slug } = Astro.params;
const path     = `/${slug ?? ""}`;
const locale   = Astro.locals.siteConfig.locale;

const page = await getPageByPath(path, locale);

if (!page || page.status !== "published") return Astro.rewrite("/404");

// Redirect pages
if (page.type === "redirect") {
  const first = page.content?.body?.[0] as (Block & { attrs?: { url?: string } }) | undefined;
  return Astro.redirect(first?.attrs?.url ?? "/", 301);
}

// Resolve all blocks in the page body with page context
const rawBlocks = (page.content?.body ?? []) as Block[];
const ctx = {
  page_ref_id:   page.ref_id   ?? undefined,
  page_ref_type: page.ref_type ?? undefined,
  currentPath:   path,
  locale,
};
const resolvedBlocks = await resolveBlocks(rawBlocks, ctx);

// If this page maps to a product, fetch it and prepend the detail component
if (page.template === "product_detail") {
  const { getProductBySlug } = await import("@/db/index");
  // path is e.g. "/chemical-earthing-electrode", remove leading slash
  const productSlug = path.replace(/^\//, "");
  const product = await getProductBySlug(productSlug);
  
  if (product) {
    resolvedBlocks.unshift({
      category: "product",
      variant: "detail",
      data: { product },
      attrs: { variant: "classic" }
    } as any);
  }
}

const seo = await getSeoMeta(page.id, locale);

// Determine if this is a full-page registry render (single root block)
// or a content page with mixed blocks
const isRegistryPage = page.template === "product_detail" || (resolvedBlocks.length === 1 && resolvedBlocks[0]?.category !== "heading");
---

<Layout
  title={seo?.meta_title ?? page.content?.title ?? page.slug}
  description={seo?.meta_description ?? page.content?.description}
>
  {isRegistryPage
    ? (
      /* Registry component fills the full content area */
      <div class="w-full">
        {resolvedBlocks.map((block) => <BlockRenderer block={block} />)}
      </div>
    )
    : (
      /* Content page — constrained prose layout */
      <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        {page.content && (
          <header class="mb-8">
            <h1 class="text-3xl sm:text-4xl font-bold tracking-tight mb-3">
              {page.content.title}
            </h1>
            {page.content.description && (
              <p class="text-lg text-muted-foreground">{page.content.description}</p>
            )}
          </header>
        )}
        <div class="space-y-4">
          {resolvedBlocks.map((block) => <BlockRenderer block={block} />)}
        </div>
      </article>
    )
  }
</Layout>

