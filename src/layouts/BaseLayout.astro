---
/**
 * BaseLayout.astro — HTML shell only.
 *
 * Provides the outer <html>, <head> (charset, viewport, title, SEO, favicon,
 * global CSS), and <body> wrapper.  Navigation, header, footer and page
 * structure are left to composing layouts (e.g. Layout.astro → PageLayout).
 *
 * Named slots
 * ───────────
 *   slot="head"  — extra <head> elements (canonical, LD+JSON, OG tags…)
 *   (default)    — body content (PageLayout or plain slot)
 */

import '@/styles/global.css';

interface Props {
  title: string;
  description?: string | null;
  canonical?: string | null;
  ogTitle?: string | null;
  ogDescription?: string | null;
  ogImage?: string | null;
  noindex?: boolean;
  nofollow?: boolean;
}

const {
  title,
  description,
  canonical,
  ogTitle,
  ogDescription,
  ogImage,
  noindex  = false,
  nofollow = false,
} = Astro.props;

const site      = Astro.locals.siteConfig;
const robots    = [noindex ? 'noindex' : 'index', nofollow ? 'nofollow' : 'follow'].join(', ');
const fullTitle = title === site?.name ? title : `${title}${site?.name ? ` | ${site.name}` : ''}`;
---

<!doctype html>
<html lang={site?.locale ?? 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <meta name="robots" content={robots} />
    {canonical && <link rel="canonical" href={canonical} />}

    <meta property="og:type"  content="website" />
    <meta property="og:title" content={ogTitle ?? title} />
    {(ogDescription ?? description) && (
      <meta property="og:description" content={ogDescription ?? description!} />
    )}
    {ogImage && <meta property="og:image" content={ogImage} />}

    {site?.favicon_url
      ? <link rel="icon" href={site.favicon_url} />
      : <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    }

    <!-- Extra head content (LD+JSON, canonical overrides, additional meta) -->
    <slot name="head" />
  </head>
  <body class="bg-background text-foreground min-h-screen">
    <slot />
  </body>
</html>
